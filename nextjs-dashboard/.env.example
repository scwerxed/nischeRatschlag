# Copy from .env.local on the Vercel dashboard
# https://nextjs.org/learn/dashboard-app/setting-up-your-database#create-a-postgres-database
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# OpenRouteService API Key (optional – Routenplaner nutzt jetzt BRouter, kein Key nötig)
NEXT_PUBLIC_ORS_API_KEY=

# Produktiv-Domain für Sitemap, robots.txt, Canonical-URLs & OpenGraph
NEXT_PUBLIC_SITE_URL=https://www.nische-ratschlag.at

# `openssl rand -base64 32`
AUTH_SECRET=
AUTH_URL=http://localhost:3000/api/auth